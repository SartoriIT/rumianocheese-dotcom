type":"main-contenido-marco","settings":{"invertir_orden":false,"imagen_fondo_seccion":"shopify:\/\/shop_images\/Background-historia.png","habilitar_imagen_fondo":true,"color_fondo":"#002554","titulo":"A Century of Craftsmanship","clase_titulo":"Titulo-Nickson-four-h1","color_titulo":"#002554","subtitulo":"A Future of Sustainability","clase_subtitulo":"Titulo-Nickson-six-h2","color_subtitulo":"#002554","texto":"<p>Since 1919, we’ve sourced organic milk from small family farms who have been using responsible regenerative practices for generations. Learn how those grass-fed, pasture-raised practices create happy cows and tasty cheese.<\/p>","color_texto":"#001b3d","ocultar_botones":true,"mostrar_dos_botones":false,"texto_boton_1":"Learn About Our Legacy  →","enlace_boton_1":"","color_boton_1":"#002554","color_texto_boton_1":"#ffffff","boton_1_transparente":false,"texto_boton_2":"Contacto","enlace_boton_2":"","color_boton_2":"#002554","color_texto_boton_2":"#ffffff","boton_2_transparente":true,"imagen_fondo_contenedor":"shopify:\/\/shop_images\/Back_Image.jpg","imagen_fondo_interior":"shopify:\/\/shop_images\/Group_14.png","habilitar_video_fondo":false,"url_video_fondo":""}},"main_contenedor_titular_cuerpo_unicolumna_QxCjeQ":{"type":"main-contenedor-titular-cuerpo-unicolumna","settings":{"background_color":"#fff9f1","habilitar_imagen_fondo":false,"imagen_fondo_seccion":"shopify:\/\/shop_images\/Imagen-fondo-home-v2.jpg","padding_top":40,"padding_bottom":40,"titulo":"Better for the Earth","clase_titulo":"Titulo-Nickson-six-h1","color_titulo":"#002554","ocultar_subtito":false,"subtitulo":"Better for You","clase_subtitulo":"Titulo-Nickson-four-h2","color_subtitulo":"#002554","texto":"<p>Careful stewardship of the land and animals ensures the best grass-fed milk for organic cheese, butter and dairy that’s equally good for people and planet.<\/p>","color_texto":"#666666","ocultar_botones":true,"mostrar_dos_botones":false,"texto_boton_1":"Explore our impact  →","enlace_boton