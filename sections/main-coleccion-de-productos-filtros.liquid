                    color: {{ section.settings.color_texto_boton_ver }};
                    border: 2px solid {{ section.settings.color_boton_ver }};
                    text-align: center;
                    text-decoration: none;
                    font-weight: 800;
                    line-height: calc(1rem + 0.8vw);
                    font-size: calc(0.6rem + 0.8vw) !important;
                  ">
                  View Product
                </a>
              {% endunless %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

{% javascript %}
  document.addEventListener('DOMContentLoaded', function() {
    console.log('Script cargado correctamente');

    // Selecciona todos los filtros
    const filtroItems = document.querySelectorAll('.filtro-item');
    if (filtroItems.length === 0) {
      console.error('No se encontraron elementos .filtro-item');
      return;
    }

    // Asigna el evento click a cada filtro
    filtroItems.forEach(item => {
      item.addEventListener('click', function() {
        const button = this.querySelector('.filtro-tipo-boton');
        if (! button) {
          console.error('No se encontró el botón dentro del filtro:', this);
          return;
        }

        const sectionId = button.dataset.section;
        const tipo = button.dataset.tipo;

        console.log(`Filtro activado: sección=${sectionId}, tipo=${tipo}`);

        // Llama a la función para filtrar productos
        filterProducts(sectionId, tipo);
      });
    });

    // Función para filtrar productos
    function filterProducts(sectionId, tipo) {
      console.log(`Filtrando productos: sección=${sectionId}, tipo=${tipo}`);

      // Desactiva todos los botones
      const buttons = document.querySelectorAll(`.filtro-tipo-${sectionId} .filtro-tipo-boton`);
      buttons.forEach(btn => {
        btn.classList.remove('active');
        btn.style.backgroundColor = 'transparent';
        btn.style.border = `2px solid {{ section.settings.color_boton_1 }}`;

        // Limpia el estilo del hijo (div)
        const childDiv = btn.querySelector('div');
        if (childDiv) {
          childDiv.style.backgroundImage = 'none';
        }
      });

      // Activa el botón correspondiente
      const activeButton = document.querySelector(`.filtro-tipo-${sectionId} .filtro-tipo-boton[data-tipo="${tipo}"]`);
      if (activeButton) {
        activeButton.classList.add('active');
        activeButton.style.backgroundColor = tipo === 'todos'
          ? '{{ section.settings.color_boton_1 }}'
          : 'transparent';
        activeButton.style.border = `2px solid {{ section.settings.color_boton_1 }}`;

        // Modifica el estilo del hijo (div) del botón activo
        const childDiv = activeButton.querySelector('div');
        if (childDiv) {
          if (tipo === 'todos') {
            childDiv.style.backgroundImage = 'url({{ section.settings.filtro_todos_imagen_activa | image_url }} )';
          } else {
            const index = activeButton.closest('.filtro-item').classList[1].split('-')[2]; // Extrae el índice del filtro
            childDiv.style.backgroundImage = `url({{ section.settings['filtro_manual_' + index + '_imagen_activa'] | image_url }})`;
          } childDiv.style.backgroundPosition = 'center';
          childDiv.style.backgroundSize = 'contain';
          childDiv.style.backgroundRepeat = 'no-repeat';
        }
      } else {
        console.error('No se encontró el botón activo para el tipo:', tipo);
      }

      // Filtra los productos
      const productCards = document.querySelectorAll(`.card-item-coleccion[data-section="${sectionId}"]`);
      productCards.forEach(card => {
        const cardType = card.dataset.tipo;
        if (tipo === 'todos') {
          card.style.display = 'block';
        } else {
          card.style.display = cardType === tipo
            ? 'block'
            : 'none';
        }
      });
    }

    // Forzar mostrar todos los productos al inicio
    setTimeout(() => {
      const defaultSectionId = '{{ section_id }}';
      filterProducts(defaultSectionId, 'todos');
    }, 100);
  });
{% endjavascript %}


