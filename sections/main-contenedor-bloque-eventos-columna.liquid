{% schema %}
{
  "name": "Contenedor Multicolumna",
  "class": "section",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#EDDEC1"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "checkbox",
      "id": "enable_background_image",
      "label": "Use solid background image",
      "default": false
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 10,
      "max": 100,
      "step": 5,
      "default": 40,
      "label": "Padding top"
    },
    {
      "type": "range",
      "id": "padding_sides",
      "min": 10,
      "max": 100,
      "step": 5,
      "default": 20,
      "label": "Lateral spaces"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 3,
      "label": "Columns in desktop version"
    },
    {
      "type": "range",
      "id": "column_gap",
      "min": 0,
      "max": 50,
      "step": 5,
      "default": 35,
      "label": "Column spacing"
    }
  ],
  "blocks": [
    {
      "type": "bloque_multicolumna",
      "name": "Bloque Multicolumna",
      "settings": [
        {
          "type": "image_picker",
          "id": "top_image",
          "label": "Image"
        },
        {
          "type": "color",
          "id": "block_background_color",
          "label": "Container color",
          "default": "#f5f5f5"
        },
        {
          "type": "checkbox",
          "id": "transparent_background",
          "label": "Make transparent background",
          "default": true
        },
        {
          "type": "text",
          "id": "title_date_event",
          "label": "Event data",
          "default": "Title"
        },
        {
          "type": "color",
          "id": "title_color_date_event",
          "label": "Color text date",
          "default": "#002554"
        },
        {
          "type": "text",
          "id": "title_bloque",
          "label": "Subtitle",
          "default": "Title"
        },
        {
          "type": "select",
          "id": "clase_title_bloque",
          "label": "Font family",
          "options": [
            { "value": "Titulo-Nickson-four-h3", "label": "Nickson Four" },
            { "value": "Titulo-Nickson-six-h3", "label": "Nickson Six" }
          ],
          "default": "Titulo-Nickson-four-h3"
        },
        {
          "type": "color",
          "id": "title_color_bloque",
          "label": "Subtitle color",
          "default": "#002554"
        },
        {
          "type": "text",
          "id": "subtitulo_bloque",
          "label": "Text",
          "default": "Title"
        },
        {
          "type": "select",
          "id": "clase_subtitulo_bloque",
          "label": "Font family",
          "options": [
            { "value": "Titulo-Nickson-four-h3", "label": "Nickson Four" },
            { "value": "Titulo-Nickson-six-h3", "label": "Nickson Six" }
          ],
          "default": "Titulo-Nickson-four-h3"
        },
        {
          "type": "color",
          "id": "subtitulo_color_bloque",
          "label": "Color text",
          "default": "#002554"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Our 100% grass-fed practices ensure the highest nutritional value and exceptional taste.</p>"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#333333"
        },
        {
          "type": "checkbox",
          "id": "mostrar_boton",
          "label": "Show bottom",
          "default": true
        },
        {
          "type": "text",
          "id": "texto_boton",
          "label": "Text bottom",
          "default": "Text"
        },
        {
          "type": "url",
          "id": "enlace_boton",
          "label": "Link bottom"
        },
        {
          "type": "color",
          "id": "color_boton",
          "label": "Color bottom",
          "default": "#002554"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Multicolumn Global Container Events",
      "category": "Secciones",
      "blocks": [
        { "type": "bloque_multicolumna" },
        { "type": "bloque_multicolumna" },
        { "type": "bloque_multicolumna" }
      ]
    }
  ]
}
{% endschema %}

<div class="section-{{ section.id }} contenedor-multicolumna-logos_columna" id="section-contenedor-multicolumna-{{ section.id }}" style="background-color: {{ section.settings.background_color }}; padding: {{ section.settings.padding_top }}px {{ section.settings.padding_sides }}px;">
  <div class="contenedor-multicolumna_columna">
    {%- for block in section.blocks -%}
      <div class="bloque-multicolumna_columna" style="background-color: {% if block.settings.transparent_background %}transparent{% else %}{{ block.settings.block_background_color }}{% endif %};" {{ block.shopify_attributes }}>
        <div class="bloque-multicolumna-contenido_columna">
          <div class="bloque-multicolumna-imagen_columna">
            {%- if block.settings.top_image != blank -%}
              <img src="{{ block.settings.top_image | image_url: width: 400 }}" alt="Image block">
            {%- endif -%}
          </div>
          <div class="bloque-multicolumna-textos_columna">
            {%- if block.settings.title_date_event != blank -%}
              <p class="Texto-Poppinds" style="color: {{ block.settings.title_color_date_event }}; margin-bottom: 0; margin-top: 0;">{{ block.settings.title_date_event }}</p>
            {%- endif -%}
            {%- if block.settings.title_bloque != blank -%}
              <h3 class="{{ block.settings.clase_title_bloque }}" style="color: {{ block.settings.title_color_bloque }};">{{ block.settings.title_bloque }}</h3>
            {%- endif -%}
            {%- if block.settings.subtitulo_bloque != blank -%}
              <h4 class="{{ block.settings.clase_subtitulo_bloque }}" style="color: {{ block.settings.subtitulo_color_bloque }}; margin-bottom: 0;">{{ block.settings.subtitulo_bloque }}</h4>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <div class="Texto-Poppinds-p-pequeño-2_columna" style="color: {{ block.settings.text_color }}; line-height: calc(1em + .8vw);">{{ block.settings.text }}</div>
            {%- endif -%}
            {%- if block.settings.mostrar_boton -%}
              <div class="boton-multicolumna_columna">
                <a href="{{ block.settings.enlace_boton }}" class="boton-generico_columna" style="background-color: {{ block.settings.color_boton }}; color: white; padding: 0.5rem 1rem; text-decoration: none; display: inline-block;">
                  {{ block.settings.texto_boton }}
                </a>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>

{%- style -%}
#section-contenedor-multicolumna-{{ section.id }} .contenedor-multicolumna_columna {
  display: flex;
  flex-direction: column;
  gap: {{ section.settings.column_gap }}px;
  width: 100%;
}

.bloque-multicolumna_columna {
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  margin: 0 auto;
}

.bloque-multicolumna-contenido_columna {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: flex-start;
  gap: 1rem;
}

.bloque-multicolumna-imagen_columna {
  flex: 0 0 auto;
}

.bloque-multicolumna-imagen_columna img {
  width: 20rem;
  height: auto;
}

.bloque-multicolumna-textos_columna {
  display: flex;
  flex-direction: column;
  flex: 1 1 auto;
  gap: 0.5rem;
}

@media (max-width: 612px) {
  .bloque-multicolumna-contenido_columna {
    flex-direction: column;
  }

  .bloque-multicolumna-imagen_columna img {
    width: 100%;
  }

  .bloque-multicolumna-textos_columna {
    width: 100%;
  }
}
{%- endstyle -%}

